# ─────────────────────────────────────────────
# Election AI Assistant — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Anthropic API — https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API Key (for Calendar, Maps, YouTube)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Google OAuth 2.0 Client ID (for Calendar sign-in)
# Enable: Google Calendar API, Maps JavaScript API, YouTube Data API v3
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Google Maps — used for polling station finder
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: App name shown in Google OAuth consent screen
VITE_APP_NAME=ElectionAI
